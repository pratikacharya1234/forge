---
import Layout from '../layouts/Layout.astro';
import DnaCanvas from '../components/3d/DnaCanvas.svelte';
import DnaSidebar from '../components/ui/DnaSidebar.svelte';
---

<Layout title="FORGE DNA - Codebase Architecture Visualizer">
	<section class="relative h-screen w-full flex flex-col pt-20">
		<div class="absolute inset-0 z-0">
			<DnaCanvas client:load />
		</div>

		<div class="relative z-10 p-8 w-full max-w-md">
			<DnaSidebar client:load />
		</div>

		<!-- Hotkey Legend -->
		<div class="absolute bottom-8 right-8 z-10 flex gap-6 text-[10px] uppercase tracking-widest font-bold text-white/30">
			<span>[LMB] Orbit</span>
			<span>[RMB] Pan</span>
			<span>[Scroll] Zoom</span>
			<span>[Click] Inspect Node</span>
		</div>
	</section>
</Layout>