---
import Layout from '../layouts/Layout.astro';
import DocsCanvas from '../components/3d/DocsCanvas.svelte';
import InteractiveCode from '../components/ui/InteractiveCode.svelte';
---

<Layout title="FORGE DOCS - Documentation">
	<div class="flex pt-16 min-h-screen">
		<!-- Sidebar -->
		<aside class="w-64 border-r border-white/5 p-8 hidden lg:block overflow-y-auto sticky top-16 h-[calc(100vh-4rem)]">
			<nav class="space-y-8">
				<div>
					<h5 class="text-[10px] uppercase tracking-widest font-bold text-white/30 mb-4">Getting Started</h5>
					<ul class="space-y-2 text-sm">
						<li><a href="#introduction" class="text-accent-primary font-medium">Introduction</a></li>
						<li><a href="#quickstart" class="text-white/60 hover:text-white transition-colors">Quickstart</a></li>
						<li><a href="#installation" class="text-white/60 hover:text-white transition-colors">Installation</a></li>
					</ul>
				</div>
				<div>
					<h5 class="text-[10px] uppercase tracking-widest font-bold text-white/30 mb-4">Core Concepts</h5>
					<ul class="space-y-2 text-sm">
						<li><a href="#multi-model" class="text-white/60 hover:text-white transition-colors">Multi-Model Routing</a></li>
						<li><a href="#tool-suite" class="text-white/60 hover:text-white transition-colors">Tool Suite</a></li>
						<li><a href="#safety" class="text-white/60 hover:text-white transition-colors">Safety System</a></li>
					</ul>
				</div>
			</nav>
		</aside>

		<!-- Content -->
		<main class="flex-1 p-8 md:p-16 max-w-4xl mx-auto">
			<article class="prose prose-invert prose-indigo max-w-none">
				<h1 id="introduction" class="text-4xl md:text-6xl font-bold tracking-tighter mb-8">INTRODUCTION</h1>
				<p class="text-xl text-white/60 leading-relaxed mb-12">
					FORGE is a relentless, autonomous AI coding agent designed to live in your terminal. It doesn't just suggest code — it ships it.
				</p>

				<div class="glass p-8 rounded-2xl mb-12 border-accent-primary/20 bg-accent-primary/5">
					<h3 class="text-xl font-bold mb-4 flex items-center gap-2">
						<span class="w-2 h-2 rounded-full bg-accent-primary animate-pulse"></span>
						Quick Install
					</h3>
					<p class="text-sm text-white/60 mb-6">Run this in your terminal to install FORGE instantly.</p>
					<InteractiveCode client:load code="curl -sSf https://forge.sh/install | sh" />
				</div>

				<h2 id="quickstart" class="text-2xl font-bold mt-16 mb-6">Quickstart</h2>
				<p class="text-white/60 mb-6">Once installed, you can start a new task using the <code>/task</code> command.</p>
				<InteractiveCode client:load code='forge /task "Implement a rate limiter in Go"' />

				<h2 id="multi-model" class="text-2xl font-bold mt-16 mb-6">Multi-Model Routing</h2>
				<p class="text-white/60 mb-6">Forge automatically routes tasks to the best model. You can also manually specify a model.</p>
				<InteractiveCode client:load code='forge /task "Refactor this component" --model claude-3-sonnet' />

				<div class="h-64 glass rounded-2xl my-16 overflow-hidden relative border-white/10">
					<div class="absolute inset-0 z-0">
						<DocsCanvas client:load />
					</div>
					<div class="absolute bottom-4 left-4 z-10 pointer-events-none">
						<span class="text-white/20 font-mono text-[10px] uppercase tracking-widest">FORGE ARCHITECTURE: EXPLODED VIEW</span>
					</div>
				</div>
			</article>
		</main>
	</div>
</Layout>
