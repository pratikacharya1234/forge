---
import Layout from '../layouts/Layout.astro';
import SecurityCanvas from '../components/3d/SecurityCanvas.svelte';
import SecuritySimulator from '../components/ui/SecuritySimulator.svelte';
import SafetyEditor from '../components/ui/SafetyEditor.svelte';
---

<Layout title="FORGE SECURITY - The Vault">
	<section class="relative h-screen w-full flex flex-col pt-20">
		<div class="absolute inset-0 z-0">
			<SecurityCanvas client:load />
		</div>

		<div class="relative z-10 container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center h-full">
			<div>
				<h2 class="text-5xl md:text-7xl font-bold tracking-tighter mb-8 bg-clip-text text-transparent bg-gradient-to-r from-white to-white/40">
					THE VAULT
				</h2>
				<p class="text-xl text-white/60 mb-12 max-w-xl">
					FORGE uses a multi-layered security architecture to ensure your system remains secure while the agent works.
				</p>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div class="glass p-6 rounded-xl border-white/5">
						<div class="text-accent-primary font-bold mb-2 uppercase tracking-widest text-[10px]">Level 1</div>
						<h4 class="font-bold mb-2">Static Analysis</h4>
						<p class="text-xs text-white/40 text-balance">Every command is scanned for dangerous patterns before execution.</p>
					</div>
					<div class="glass p-6 rounded-xl border-white/5">
						<div class="text-accent-secondary font-bold mb-2 uppercase tracking-widest text-[10px]">Level 2</div>
						<h4 class="font-bold mb-2">Runtime Protection</h4>
						<p class="text-xs text-white/40 text-balance">Real-time monitoring of shell pipes and unexpected child processes.</p>
					</div>
					<div class="glass p-6 rounded-xl border-white/5">
						<div class="text-gemini font-bold mb-2 uppercase tracking-widest text-[10px]">Level 3</div>
						<h4 class="font-bold mb-2">User Guardrails</h4>
						<p class="text-xs text-white/40 text-balance">Configurable safety policies via .forge/safety.toml.</p>
					</div>
					<div class="glass p-6 rounded-xl border-white/5">
						<div class="text-claude font-bold mb-2 uppercase tracking-widest text-[10px]">Level 4</div>
						<h4 class="font-bold mb-2">Air-Gap Ready</h4>
						<p class="text-xs text-white/40 text-balance">Run local models for zero-data-leak environments.</p>
					</div>
				</div>
			</div>

			<div class="hidden lg:block">
				<SecuritySimulator client:load />
			</div>
		</div>

		<div class="relative z-10 container mx-auto px-6 pb-24 mt-24">
			<div class="max-w-4xl mx-auto">
				<SafetyEditor client:load />
			</div>
		</div>
	</section>
</Layout>
