---
import Layout from '../layouts/Layout.astro';
import ArenaBattleground from '../components/ui/ArenaBattleground.svelte';
---

<Layout title="FORGE ARENA - Model Battleground">
	<section class="pt-32 pb-24 min-h-screen">
		<div class="container mx-auto px-6 text-center mb-16">
			<h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">MODEL ARENA</h2>
			<p class="text-white/60 max-w-2xl mx-auto">
				Witness the ultimate coding showdown. We run the same task across the world's leading models and let FORGE orchestrate the winner.
			</p>
		</div>

		<ArenaBattleground client:load />
	</section>
</Layout>
